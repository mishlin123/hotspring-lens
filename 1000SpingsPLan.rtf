\f3\b0\fs26 \cf0 create extension if not exists postgis;\
\
create table public.springs (\
  id uuid primary key default gen_random_uuid(),\
  source_sample_id text unique,\
  sample_number text,\
  name text not null,\
  location_text text,\
  district text,\
  geothermal_system text,\
  feature_type text,\
  sample_date date,\
  description text,\
\
  latitude double precision,\
  longitude double precision,\
  location geography(Point, 4326),\
  location_precision text default 'unknown',\
  public_location_allowed boolean default false,\
  show_in_camera_overlay boolean default false,\
\
  access_status text default 'unknown',\
  safety_status text default 'unknown',\
  safety_notes text,\
\
  temperature_c numeric,\
  ph numeric,\
  size_approx text,\
  ebullition text,\
  oxidation_reduction_potential_mv numeric,\
  conductivity_us_cm numeric,\
  dissolved_oxygen_mg_l numeric,\
  turbidity_fnu numeric,\
\
  sample_site_status text,\
  physical_measurements_status text,\
  chemistry_status text,\
  sequencing_data_status text,\
\
  source_url text not null,\
  source_licence text not null default 'CC BY-NC-SA 4.0',\
  accessed_at timestamptz,\
  needs_manual_review boolean default true,\
\
  created_at timestamptz default now(),\
  updated_at timestamptz default now()\
);\
\
create index springs_location_idx on public.springs using gist(location);\
create index springs_ph_idx on public.springs(ph);\
create index springs_temperature_idx on public.springs(temperature_c);\
create table public.chemical_measurements (\
  id uuid primary key default gen_random_uuid(),\
  spring_id uuid references public.springs(id) on delete cascade,\
  analyte text not null,\
  value numeric,\
  unit text,\
  source_url text,\
  accessed_at timestamptz,\
  confidence text default 'imported'\
);\
create table public.microbial_taxa (\
  id uuid primary key default gen_random_uuid(),\
  spring_id uuid references public.springs(id) on delete cascade,\
  domain text,\
  phylum text,\
  class text,\
  tax_order text,\
  family text,\
  genus text,\
  species text,\
  relative_abundance_percent numeric,\
  taxonomic_rank text,\
  assignment_confidence text,\
  source_url text,\
  accessed_at timestamptz,\
  needs_manual_review boolean default true\
);\
create table public.cultural_context (\
  id uuid primary key default gen_random_uuid(),\
  spring_id uuid references public.springs(id) on delete cascade,\
  title text,\
  body text,\
  iwi_hapu_context text,\
  source text,\
  permission_status text default 'not_reviewed',\
  reviewer text,\
  reviewed_at date,\
  public_visibility text default 'hidden',\
  notes text\
);\
create table public.content_cards (\
  id uuid primary key default gen_random_uuid(),\
  spring_id uuid references public.springs(id) on delete cascade,\
  card_type text not null,\
  title text not null,\
  plain_language_body text,\
  expert_body text,\
  source_url text,\
  needs_manual_review boolean default true\
);\
