\f0\b\fs28 \cf0 Nearby function\
\pard\pardeftab720\partightenfactor0

\f3\b0\fs26 \cf0 create or replace function public.nearby_public_springs(\
  user_lat double precision,\
  user_lng double precision,\
  radius_m integer default 2000\
)\
returns table (\
  id uuid,\
  name text,\
  source_sample_id text,\
  distance_m double precision,\
  latitude double precision,\
  longitude double precision,\
  temperature_c numeric,\
  ph numeric,\
  access_status text,\
  safety_status text\
)\
language sql\
stable\
as $$\
  select\
    s.id,\
    s.name,\
    s.source_sample_id,\
    st_distance(\
      s.location,\
      st_setsrid(st_makepoint(user_lng, user_lat), 4326)::geography\
    ) as distance_m,\
    s.latitude,\
    s.longitude,\
    s.temperature_c,\
    s.ph,\
    s.access_status,\
    s.safety_status\
  from public.springs s\
  where\
    s.location is not null\
    and s.public_location_allowed = true\
    and s.show_in_camera_overlay = true\
    and st_dwithin(\
      s.location,\
      st_setsrid(st_makepoint(user_lng, user_lat), 4326)::geography,\
      radius_m\
    )\
  order by distance_m asc;\
$$;\
\pard\pardeftab720\partightenfactor0

